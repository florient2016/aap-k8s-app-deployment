<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="description" content="Page d’accueil — industrialiser l’exploitation cloud hybride." />
    <meta name="theme-color" content="#0b1020" />
    <title>{{ app_title }}</title>

    <style>
      :root{
        --bg0:#070a13;
        --bg1:#0b1020;
        --card:#0f1730cc;
        --card2:#0f1730;
        --text:#eaf0ff;
        --muted:#b8c3e0;
        --accent:#6ee7ff;
        --accent2:#9b7bff;
        --ok:#37d67a;
        --warn:#ffcc66;
        --shadow: 0 20px 60px rgba(0,0,0,.45);
        --radius: 18px;
      }

      *{ box-sizing:border-box; }
      html,body{ height:100%; }
      body{
        margin:0;
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji","Segoe UI Emoji";
        color:var(--text);
        background:
          radial-gradient(1200px 800px at 15% 10%, rgba(110,231,255,.15), transparent 55%),
          radial-gradient(900px 600px at 85% 20%, rgba(155,123,255,.16), transparent 60%),
          radial-gradient(900px 900px at 70% 95%, rgba(55,214,122,.10), transparent 55%),
          linear-gradient(180deg, var(--bg0), var(--bg1));
        overflow-x:hidden;
      }

      a{ color:inherit; text-decoration:none; }
      .wrap{
        min-height:100%;
        display:flex;
        flex-direction:column;
      }

      header{
        position:sticky;
        top:0;
        backdrop-filter: blur(10px);
        background: linear-gradient(180deg, rgba(7,10,19,.75), rgba(7,10,19,.35));
        border-bottom:1px solid rgba(234,240,255,.08);
        z-index:10;
      }

      .nav{
        max-width:1100px;
        margin:0 auto;
        padding:14px 18px;
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap:12px;
      }

      .brand{
        display:flex;
        align-items:center;
        gap:12px;
        min-width: 240px;
      }

      .logo{
        width:40px;height:40px;
        border-radius: 12px;
        background:
          radial-gradient(circle at 30% 30%, rgba(110,231,255,.95), transparent 55%),
          radial-gradient(circle at 70% 70%, rgba(155,123,255,.95), transparent 55%),
          linear-gradient(135deg, rgba(255,255,255,.10), rgba(255,255,255,.02));
        box-shadow: 0 10px 30px rgba(0,0,0,.35);
        border:1px solid rgba(234,240,255,.12);
      }

      .brand small{
        display:block;
        color:var(--muted);
        font-weight:500;
        letter-spacing:.2px;
        margin-top:2px;
      }

      .links{
        display:flex;
        align-items:center;
        gap:10px;
        flex-wrap:wrap;
        justify-content:flex-end;
      }

      .chip{
        padding:8px 10px;
        border-radius: 999px;
        border:1px solid rgba(234,240,255,.10);
        background: rgba(15,23,48,.35);
        color:var(--muted);
        font-size:13px;
        display:flex;
        align-items:center;
        gap:8px;
      }

      .dot{
        width:8px;height:8px;border-radius:50%;
        background: var(--ok);
        box-shadow: 0 0 0 3px rgba(55,214,122,.15);
      }

      main{
        flex:1;
        max-width:1100px;
        margin:0 auto;
        padding: 36px 18px 44px;
        width:100%;
      }

      .hero{
        display:grid;
        grid-template-columns: 1.15fr .85fr;
        gap:18px;
        align-items:stretch;
      }

      @media (max-width: 900px){
        .hero{ grid-template-columns: 1fr; }
        .brand{ min-width:auto; }
      }

      .card{
        background: rgba(15,23,48,.55);
        border:1px solid rgba(234,240,255,.10);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        overflow:hidden;
        position:relative;
      }

      .card::before{
        content:"";
        position:absolute;
        inset:-2px;
        background: linear-gradient(135deg, rgba(110,231,255,.22), rgba(155,123,255,.18), rgba(55,214,122,.10));
        opacity:.45;
        filter: blur(18px);
        z-index:0;
      }

      .card > *{ position:relative; z-index:1; }

      .hero-left{
        padding: 26px 24px 22px;
      }

      h1{
        margin:0 0 8px;
        font-size: clamp(26px, 3vw, 38px);
        line-height:1.15;
        letter-spacing:-.4px;
      }

      .subtitle{
        margin:0 0 16px;
        color:var(--muted);
        font-size: 15.5px;
        line-height:1.55;
        max-width: 62ch;
      }

      .badges{
        display:flex;
        flex-wrap:wrap;
        gap:10px;
        margin-top: 14px;
      }

      .badge{
        padding:10px 12px;
        border-radius: 14px;
        background: rgba(7,10,19,.45);
        border: 1px solid rgba(234,240,255,.10);
        color: var(--text);
        font-size: 13px;
        display:flex;
        align-items:center;
        gap:10px;
      }

      .badge svg{ opacity:.95; }

      .hero-right{
        padding: 18px;
        display:flex;
        flex-direction:column;
        gap:12px;
      }

      .kpi{
        padding: 14px 14px;
        border-radius: 16px;
        border:1px solid rgba(234,240,255,.10);
        background: rgba(7,10,19,.35);
      }
      .kpi strong{
        display:block;
        font-size: 18px;
        letter-spacing:-.2px;
        margin-bottom:4px;
      }
      .kpi span{
        color: var(--muted);
        font-size: 13px;
        line-height:1.5;
      }

      .grid{
        margin-top: 18px;
        display:grid;
        grid-template-columns: repeat(3, 1fr);
        gap:14px;
      }

      @media (max-width: 900px){
        .grid{ grid-template-columns: 1fr; }
      }

      .tile{
        padding: 16px 16px;
        border-radius: 18px;
        border:1px solid rgba(234,240,255,.10);
        background: rgba(15,23,48,.35);
      }

      .tile h3{
        margin: 0 0 8px;
        font-size: 15px;
      }
      .tile p{
        margin:0;
        color: var(--muted);
        font-size: 13.5px;
        line-height:1.55;
      }

      .steps{
        margin-top: 18px;
        padding: 18px;
      }

      .steps h2{
        margin: 0 0 12px;
        font-size: 16px;
        letter-spacing:-.2px;
      }

      .timeline{
        display:grid;
        grid-template-columns: 1fr;
        gap:10px;
      }

      .step{
        display:flex;
        gap:12px;
        align-items:flex-start;
        padding: 12px 12px;
        border-radius: 16px;
        border:1px solid rgba(234,240,255,.10);
        background: rgba(7,10,19,.30);
      }
      .n{
        width:28px;height:28px;
        border-radius: 12px;
        display:flex;
        align-items:center;
        justify-content:center;
        background: linear-gradient(135deg, rgba(110,231,255,.35), rgba(155,123,255,.25));
        border:1px solid rgba(234,240,255,.12);
        font-weight:700;
        font-size: 13px;
      }

      footer{
        border-top:1px solid rgba(234,240,255,.08);
        background: rgba(7,10,19,.55);
      }

      .foot{
        max-width:1100px;
        margin:0 auto;
        padding: 16px 18px;
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap:10px;
        color: var(--muted);
        font-size: 12.5px;
        flex-wrap:wrap;
      }

      .pill{
        padding:8px 10px;
        border-radius: 999px;
        border:1px solid rgba(234,240,255,.10);
        background: rgba(15,23,48,.35);
      }

      /* Accessibilité */
      :focus-visible{
        outline: 3px solid rgba(110,231,255,.55);
        outline-offset: 3px;
        border-radius: 10px;
      }
    </style>
  </head>

  <body>
    <div class="wrap">
      <header>
        <div class="nav">
          <div class="brand" aria-label="Brand">
            <div class="logo" aria-hidden="true"></div>
            <div>
              <div style="font-weight:800; letter-spacing:-.2px;">{{ app_title }}</div>
              <small>Industrialiser l’exploitation cloud hybride · de la configuration à l’orchestration</small>
            </div>
          </div>

          <nav class="links" aria-label="Navigation">
            <div class="chip" title="Statut de la plateforme">
              <span class="dot" aria-hidden="true"></span>
              <span>Plateforme prête</span>
            </div>
            <div class="chip" title="Mode">
              <span aria-hidden="true">🛡️</span>
              <span>Bonnes pratiques</span>
            </div>
            <div class="chip" title="Objectif">
              <span aria-hidden="true">⚙️</span>
              <span>Automatisation</span>
            </div>
          </nav>
        </div>
      </header>

      <main>
        <section class="hero">
          <article class="card hero-left">
            <h1>{{ app_title }}</h1>
            <p class="subtitle">
              Cette page sert de vitrine simple pour votre formation : un point d’entrée clair
              vers les fondamentaux de l’industrialisation en cloud hybride (configurations, standards,
              orchestration, observabilité et sécurité).
            </p>

            <div class="badges" aria-label="Thématiques">
              <div class="badge">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M7 7h10v10H7V7Z" stroke="rgba(234,240,255,.9)" stroke-width="1.7"/>
                  <path d="M4 12h3M17 12h3M12 4v3M12 17v3" stroke="rgba(234,240,255,.65)" stroke-width="1.7" stroke-linecap="round"/>
                </svg>
                <span>Configuration standardisée</span>
              </div>

              <div class="badge">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M7 12a5 5 0 1 1 10 0" stroke="rgba(234,240,255,.9)" stroke-width="1.7" stroke-linecap="round"/>
                  <path d="M8 12h8M9 16h6" stroke="rgba(234,240,255,.65)" stroke-width="1.7" stroke-linecap="round"/>
                </svg>
                <span>Orchestration &amp; déploiement</span>
              </div>

              <div class="badge">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M12 3l8 4v6c0 5-3.5 8.5-8 9-4.5-.5-8-4-8-9V7l8-4Z" stroke="rgba(234,240,255,.9)" stroke-width="1.7"/>
                  <path d="M9.5 12l1.8 1.8L15.7 9.5" stroke="rgba(55,214,122,.95)" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>Sécurité &amp; conformité</span>
              </div>
            </div>
          </article>

          <aside class="card hero-right" aria-label="Résumé">
            <div class="kpi">
              <strong>Objectif</strong>
              <span>Passer d’une configuration manuelle à une exploitation industrialisée et traçable.</span>
            </div>
            <div class="kpi">
              <strong>Livrables</strong>
              <span>Standards · IaC · GitOps · Pipelines · Monitoring · Runbooks.</span>
            </div>
            <div class="kpi">
              <strong>Résultat attendu</strong>
              <span>Moins d’erreurs, des déploiements reproductibles, une meilleure disponibilité.</span>
            </div>
          </aside>
        </section>

        <section class="grid" aria-label="Domaines clés">
          <div class="tile">
            <h3>Infrastructure as Code</h3>
            <p>Décrire, versionner et reproduire l’infrastructure de manière cohérente sur plusieurs environnements.</p>
          </div>
          <div class="tile">
            <h3>GitOps &amp; Orchestration</h3>
            <p>Automatiser le déploiement, contrôler les changements et faciliter les rollbacks en production.</p>
          </div>
          <div class="tile">
            <h3>Observabilité</h3>
            <p>Logs, métriques, traces et alerting : visibilité complète pour réduire le MTTR et fiabiliser.</p>
          </div>
        </section>

        <section class="card steps" aria-label="Parcours">
          <h2>Parcours recommandé (exemple)</h2>
          <div class="timeline">
            <div class="step">
              <div class="n">1</div>
              <div>
                <div style="font-weight:700; margin-bottom:2px;">Standardiser</div>
                <div style="color:var(--muted); font-size:13.5px; line-height:1.55;">
                  Baselines, conventions, templates, gestion des secrets et exigences de sécurité.
                </div>
              </div>
            </div>

            <div class="step">
              <div class="n">2</div>
              <div>
                <div style="font-weight:700; margin-bottom:2px;">Automatiser</div>
                <div style="color:var(--muted); font-size:13.5px; line-height:1.55;">
                  Pipelines CI/CD, validations, scans, déploiements reproductibles et promotion d’environnements.
                </div>
              </div>
            </div>

            <div class="step">
              <div class="n">3</div>
              <div>
                <div style="font-weight:700; margin-bottom:2px;">Orchestrer</div>
                <div style="color:var(--muted); font-size:13.5px; line-height:1.55;">
                  GitOps, politiques, opérateurs, et automatisations d’exploitation (self-healing, scaling).
                </div>
              </div>
            </div>
          </div>
        </section>
      </main>

      <footer>
        <div class="foot">
          <div class="pill">© <span id="y"></span> — {{ app_title }}</div>
          <div>Front statique (Jinja2) · 1 variable · prêt à intégrer à Ansible / Helm / CI</div>
        </div>
      </footer>
    </div>

    <script>
      // 100% statique côté contenu ; juste l'année pour l'affichage.
      document.getElementById("y").textContent = new Date().getFullYear();
    </script>
  </body>
</html>